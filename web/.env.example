# Local development (defaults)
NEXT_PUBLIC_APP_URL=http://localhost:3120
NEXT_PUBLIC_API_URL=http://localhost:3130

# Production (Vercel) — set these in the Vercel dashboard:
# NEXT_PUBLIC_APP_URL=https://www.ranasi.com
# NEXT_PUBLIC_API_URL=https://api.ranasi.com

# Chrome Web Store listing (production users install from here — never a folder)
# NEXT_PUBLIC_EXTENSION_URL=https://chrome.google.com/webstore/detail/ranasi/XXXXXXXX

# Optional mirror of checkout link (API env is source of truth for Pay button)
# NEXT_PUBLIC_CHECKOUT_URL=https://YOUR_STORE.lemonsqueezy.com/checkout/buy/VARIANT_ID

ALLOW_DEV_LICENSE=true
