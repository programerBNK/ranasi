# Local Docker Postgres (npm run dev:db)
# DATABASE_URL=postgres://ranasi:ranasi@127.0.0.1:5433/ranasi

# Supabase — paste Session / URI from Project Settings → Database
# Use the password from Supabase (URL-encode special chars: / → %2F, @ → %40, % → %25)
# Direct:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require
# Pooler (recommended on Railway / serverless):
# DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

DATABASE_URL=
HOST=0.0.0.0
PORT=3130

# Local: true · Railway production: false
ALLOW_DEV_LICENSE=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FILL_DAILY_LIMIT=200

LEMONSQUEEZY_WEBHOOK_SECRET=
# Optional if you create checkouts from API
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_VARIANT_ID=
# APP_URL=https://your-web.vercel.app

RUST_LOG=info,ranasi_api=debug
